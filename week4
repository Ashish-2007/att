package week_4;

import java.time.Duration;
import java.util.Arrays;
import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.chrome.ChromeOptions;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;

public class Week4 {

    public static void main(String[] args) {

        // Set ChromeDriver path
        System.setProperty("webdriver.chrome.driver",
                "D:\\ATT driver\\chromedriver-win64\\chromedriver.exe");

        ChromeOptions options = new ChromeOptions();
        WebDriver driver = new ChromeDriver(options);
        driver.manage().window().maximize();

        // List of bank URLs
        List<String> bankUrls = Arrays.asList("https://www.axisbank.com/","https://www.hdfcbank.com/","https://www.icicibank.com/","https://www.sbi.co.in/");

        WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(10));

        for (String url : bankUrls) {
            driver.get(url);
            System.out.println("Opened: " + url);

            try {
                WebElement popupClose = wait.until(
                        ExpectedConditions.elementToBeClickable( By.xpath("//button[contains(@class,'close')] | " +"//span[contains(@class,'close')] | " +"//div[contains(@class,'close')] | " +"//button[text()='x' or text()='X']"
                                )
                        )
                );

                popupClose.click();
                System.out.println("Website pop-up closed");

            } catch (Exception e) {
                System.out.println("No website pop-up displayed");
            }

            try {
                Thread.sleep(2000);
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
            }
        }

        driver.wait();
    }
}
